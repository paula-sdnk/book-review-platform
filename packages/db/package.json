{
  "name": "@book-review-platform/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "import:books": "tsx ./scripts/import-books.ts"
  },
  "dependencies": {
    "@book-review-platform/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@book-review-platform/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
