{
  "name": "book-review-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r check-types",
    "dev:web": "pnpm --filter web dev",
    "db:push": "pnpm --filter @book-review-platform/db db:push",
    "db:studio": "pnpm --filter @book-review-platform/db db:studio",
    "db:generate": "pnpm --filter @book-review-platform/db db:generate",
    "db:migrate": "pnpm --filter @book-review-platform/db db:migrate",
    "db:start": "pnpm --filter @book-review-platform/db db:start",
    "db:watch": "pnpm --filter @book-review-platform/db db:watch",
    "db:stop": "pnpm --filter @book-review-platform/db db:stop",
    "db:down": "pnpm --filter @book-review-platform/db db:down"
  },
  "dependencies": {
    "@book-review-platform/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@book-review-platform/config": "workspace:*",
    "@types/node": "^22.13.14",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.32.1"
}
